# Django Settings
DEBUG=False
SECRET_KEY=your-super-secret-key-here-change-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,your-backend.koyeb.app,your-backend.fly.dev

# Database
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require
# Or for SQLite (local only):
# DATABASE_URL=sqlite:///db.sqlite3

# CORS & CSRF
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app

# WebSockets
REDIS_URL=

# AI providers
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# GitHub OAuth for SEA
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=https://your-backend.koyeb.app/api/agent/github/oauth/callback/
GITHUB_OAUTH_ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Authentication
AUTH_USER_MODEL=accounts.CustomUser

# JWT Settings
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=3600  # 60 minutes
JWT_REFRESH_TOKEN_LIFETIME=86400  # 24 hours

# Email (optional)
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# AWS S3 (optional, for media files)
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Admin
ADMIN_URL=/admin/
